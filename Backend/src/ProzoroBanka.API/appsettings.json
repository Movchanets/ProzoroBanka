{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Key": "CHANGE_ME_SuperSecretKeyAtLeast32Chars!!",
    "RefreshKey": "CHANGE_ME_SeparateRefreshSecretAtLeast32Chars!!",
    "Issuer": "MyAPPServer",
    "Audience": "MyAPPClient",
    "AccessTokenExpirationMinutes": "15",
    "RefreshTokenExpirationDays": "7"
  },
  "Email": {
    "Provider": "smtp",
    "FromAddress": "noreply@example.com",
    "FromName": "My App <noreply@example.com>",
    "Resend": {
      "ApiKey": "",
      "BaseUrl": "https://api.resend.com/"
    },
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 587,
      "EnableSsl": true,
      "Username": "",
      "Password": ""
    }
  },
  "Google": {
    "ClientId": "",
    "ClientSecret": ""
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Turnstile": {
    "SecretKey": "",
    "VerifyUrl": "https://challenges.cloudflare.com/turnstile/v0/siteverify"
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "AuthCookies": {
    "AccessTokenCookieName": "pb_access_token",
    "RefreshTokenCookieName": "pb_refresh_token",
    "CsrfTokenCookieName": "pb_csrf_token",
    "CsrfHeaderName": "X-CSRF-TOKEN",
    "SameSite": "Lax",
    "Secure": true,
    "Path": "/",
    "Domain": null,
    "Enabled": true
  },
  "Redis": {
    "Enabled": false,
    "ConnectionString": "localhost:6379"
  },
  "RateLimiting": {
    "Enabled": true,
    "General": {
      "PermitLimit": 100,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Auth": {
      "PermitLimit": 10,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  },
  "Storage": {
    "Provider": "Local",
    "Local": {
      "FolderName": "uploads"
    },
    "R2": {
      "AccountId": "",
      "AccessKey": "",
      "SecretKey": "",
      "BucketName": "",
      "PublicUrl": ""
    },
    "S3": {
      "Region": "",
      "AccessKey": "",
      "SecretKey": "",
      "BucketName": "",
      "PublicUrl": "",
      "ServiceUrl": ""
    },
    "Azure": {
      "ConnectionString": "",
      "ContainerName": "uploads",
      "CdnUrl": ""
    },
    "MinIO": {
      "ServiceUrl": "",
      "AccessKey": "",
      "SecretKey": "",
      "BucketName": "",
      "PublicUrl": ""
    }
  },
  "Ocr": {
    "UseExtractionStub": false,
    "Mistral": {
      "ApiKey": "",
      "BaseUrl": "https://api.mistral.ai",
      "TimeoutSeconds": 60
    },
    "OpenRouter": {
      "ApiKey": "",
      "BaseUrl": "https://openrouter.ai/api",
      "TimeoutSeconds": 60
    }
  },
  "StateValidator": {
    "Enabled": true,
    "DailyLimitPerToken": 900,
    "BaseUrl": "https://cabinet.tax.gov.ua",
    "TimeoutSeconds": 20,
    "Fiscal": {
      "EndpointPath": "/ws/api_public/rro/chkAll",
      "DocumentType": 3
    },
    "BankTransfer": {
      "EndpointPath": "/ws/api/public/registers/registration"
    }
  },
  "Encryption": {
    "Key": "CHANGE_ME_Base64_32ByteKey_For_AES256"
  },
  "Seed": {
    "Admin": {
      "Email": "admin@example.com",
      "Password": "",
      "FirstName": "System",
      "LastName": "Administrator"
    }
  },
  "OrganizationPlans": {
    "MaxOwnedOrganizationsForNonAdmin": 10,
    "MaxJoinedOrganizationsForNonAdmin": 20,
    "Free": {
      "MaxCampaigns": 3,
      "MaxMembers": 10,
      "MaxOcrExtractionsPerMonth": 100
    },
    "Paid": {
      "MaxCampaigns": 100,
      "MaxMembers": 200,
      "MaxOcrExtractionsPerMonth": 5000
    }
  }
}
